@model Author

<h2>@Model.Name</h2>
<p>@Model.Bio</p>
<hr />

<h4>Книги автора</h4>
@if (Model.Books != null && Model.Books.Any())
{
	<ul>
		@foreach (var book in Model.Books)
		{
			<li>
				<a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id">@book.Name</a>
				- @book.Price.ToString("C")
			</li>
		}
	</ul>
}
else
{
	<p>У этого автора пока нет добавленных книг в каталоге.</p>
}

<a asp-action="Index" class="btn btn-secondary mt-3">Назад к списку</a>